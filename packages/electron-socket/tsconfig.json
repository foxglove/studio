{
  "extends": "../../tsconfig.json",
  "include": ["**/*.ts", "./typings/*.d.ts"],
  "compilerOptions": {
    "module": "es2020",
    "lib": ["es2020", "dom"],
    "declaration": true,
    "rootDir": ".",
    "noUnusedParameters": true,
    "noEmit": true,
    "typeRoots": ["node_modules/@types", "./typings"],
    "paths": {
      "dns-packet": ["./typings/dns-packet"],
      "multicast-dns": ["./typings/multicast-dns"]
    }
  }
}
