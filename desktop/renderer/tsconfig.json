{
  "extends": "@foxglove/tsconfig/base",
  "include": ["./**/*", "../common/**/*", "../../package.json"],
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "rootDir": "../../",
    "noEmit": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "useUnknownInCatchVariables": false,
    "lib": ["dom", "dom.iterable", "esnext", "webworker"]
  }
}
